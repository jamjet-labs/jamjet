# vhs tape script for examples/database-safety
# Run: vhs demo.tape  →  produces demo.gif
# See: https://github.com/charmbracelet/vhs

Output demo.gif

Set FontSize 14
Set Width 920
Set Height 720
Set Padding 18
Set TypingSpeed 55ms
Set Theme "Dracula"

Type "python main.py"
Sleep 700ms
Enter
Sleep 7s
