{
  "name": "jamjet-typescript-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "JamJet TypeScript SDK monorepo (workspace root, not published)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "size": "pnpm -r size",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
